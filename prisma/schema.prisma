generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id              String            @id
  name            String
  sportId         String
  country         String
  image           String?
  achievements    Json?
  bio             String?
  careerTimeline  Json?
  stats           Json?
  updatedAt       DateTime?         @db.Timestamp(6)
  Sport           Sport             @relation(fields: [sportId], references: [id])
  PlayerToStadium PlayerToStadium[]
}

model QRMapping {
  id                    String   @id
  qrCode                String   @unique
  stadiumId             String
  locationInsideStadium String?
  createdAt             DateTime @default(now())
  appDeepLink           String?
  qrImageData           String?
  qrImageUrl            String?
  qrPayload             String?
  scanUrl               String?
  updatedAt             DateTime
  Stadium               Stadium  @relation(fields: [stadiumId], references: [id])
}

model Sport {
  id             String           @id
  name           String
  description    String
  icon           String?
  rulebookVideos Json?
  Player         Player[]
  SportToStadium SportToStadium[]
}

model Stadium {
  id               String            @id
  name             String
  city             String
  state            String
  country          String            @default("India")
  capacity         Int
  builtYear        Int
  description      String
  latitude         Float?
  longitude        Float?
  galleryImages    Json?
  historyTimeline  Json?
  legendaryMoments Json?
  tournaments      Json?
  upcomingMatches  Json?
  nearbyPlaces     Json?
  QRMapping        QRMapping[]
  Visit            Visit[]
  PlayerToStadium  PlayerToStadium[]
  SportToStadium   SportToStadium[]
}

model User {
  id        String   @id
  clerkId   String   @unique
  email     String?
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Visit     Visit[]
}

model Visit {
  id        String   @id
  userId    String
  stadiumId String
  createdAt DateTime @default(now())
  Stadium   Stadium  @relation(fields: [stadiumId], references: [id])
  User      User     @relation(fields: [userId], references: [id])

  @@index([stadiumId])
  @@index([userId])
}

model PlayerToStadium {
  A       String
  B       String
  Player  Player  @relation(fields: [A], references: [id], onDelete: Cascade)
  Stadium Stadium @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_PlayerToStadium_AB_pkey")
  @@index([B], map: "_PlayerToStadium_B_index")
  @@map("_PlayerToStadium")
}

model SportToStadium {
  A       String
  B       String
  Sport   Sport   @relation(fields: [A], references: [id], onDelete: Cascade)
  Stadium Stadium @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_SportToStadium_AB_pkey")
  @@index([B], map: "_SportToStadium_B_index")
  @@map("_SportToStadium")
}
